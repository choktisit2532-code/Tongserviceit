NODE_ENV=development
PORT=3000

# Supabase: Connect > Session pooler (recommended for Render/IPv4)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=5

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h

# Comma-separated. Add your Vercel production/preview domains.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,tongserviceit.vercel.app

# Feature flags prepared for future use
FEATURE_REALTIME=false
FEATURE_AUTOMATIC_BACKUP=false
FEATURE_EMAIL_NOTIFICATIONS=false
